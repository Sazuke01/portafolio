---
import './styles/conocimientos.css';
---

<div class="page-wrap" id="conocimientos">
  <div></div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    fetch('/data/conocimientos.json')
      .then((res) => res.json())
      .then((data) => {
        const container = document.querySelector('#conocimientos > div');
        if (!container) return;

        // Habilidades Técnicas
        const habilidadesHtml = data.habilidades
          .map(
            (hab: string) => `<div class="skill-item"><div class="skill-bullet"></div>${hab}</div>`,
          )
          .join('');

        // Lenguajes
        const lenguajesHtml = data.lenguajes
          .map(
            (lang: any) =>
              `<div class="lang-row">
                <div class="lang-label">${lang.nombre} <span>${lang.nivel}</span></div>
                <div class="bar-track"><div class="bar-fill" style="width:${lang.porcentaje}%"></div></div>
              </div>`,
          )
          .join('');

        const interesesHtml =
          data.interesesActivos && data.interesesActivos.length > 0
            ? `<div style="margin-top:10px; font-size:11.5px; font-family:'Segoe UI',sans-serif; color:var(--ink-muted);">Interés activo en: <strong style="color:var(--accent);">${data.interesesActivos.join(' · ')}</strong></div>`
            : '';

        // Tecnologías
        const tecnologiasHtml = data.tecnologias
          .map((tech: string) => `<span class="tag">${tech}</span>`)
          .join('');

        // Áreas de Interés
        const areasHtml = data.areasInteres
          .map(
            (area: string) =>
              `<span class="tag" style="background:#e8f4e8;border-color:#9ecf9e;color:#2a6b2a;">${area}</span>`,
          )
          .join('');

        // Idiomas
        const idiomasHtml = data.idiomas
          .map(
            (idioma: any) =>
              `<div>${idioma.idioma} &nbsp;—&nbsp; <span style="color:var(--accent);font-weight:600;">${idioma.nivel}</span>${idioma.detalle ? `<span style="color:var(--ink-muted);font-size:11.5px;"> ${idioma.detalle}</span>` : ''}</div>`,
          )
          .join('');

        container.innerHTML = `
          <section class="sections">
            <div class="sections-title">Habilidades Técnicas</div>
            <div class="skills-grid">
              ${habilidadesHtml}
            </div>
          </section>

          <hr class="inner-rule" />

          <div class="two-col">
            <section class="sections">
              <div class="sections-title">Lenguajes</div>
              <div class="lang-grid" style="grid-template-columns:1fr;">
                ${lenguajesHtml}
              </div>
              ${interesesHtml}
            </section>

            <section class="sections">
              <div class="sections-title">Tecnologías</div>
              <div class="tag-cloud" style="margin-bottom:14px;">
                ${tecnologiasHtml}
              </div>

              <div class="sections-title" style="margin-top:14px;">Áreas de Interés</div>
              <div class="tag-cloud" style="margin-bottom:14px;">
                ${areasHtml}
              </div>

              <div class="sections-title" style="margin-top:14px;">Idiomas</div>
              <div style="font-family:'Segoe UI',sans-serif; font-size:12.5px; color:var(--ink-soft); display:flex; flex-direction:column; gap:4px;">
                ${idiomasHtml}
              </div>
            </section>
          </div>
        `;
      })
      .catch((error) => console.error('Error cargando conocimientos:', error));
  });
</script>
