<style>
  footer {
    bottom: 0;

    box-sizing: border-box;

    margin-right: 4rem;

    z-index: 90;
  }

  footer {
    background-color: var(--secondary);
    color: var(--primary);
  }

  .footer-content {
    padding: 1rem;
    div {
      margin: 2.5px;
    }
  }

  .footer-icon {
    margin-bottom: 3px;
    width: 22px;
    height: 22px;
    vertical-align: middle;

    fill: var(--primary);
  }

  @media (max-width: 800px) {
    .footer-content div hr {
      display: none;
    }
  }
</style>
